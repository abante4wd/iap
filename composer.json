{
    "name": "fukazawa/iap",
    "description": "Framework-agnostic in-app purchase verification package for Google Play and Apple App Store",
    "type": "library",
    "license": "MIT",
    "keywords": ["iap", "in-app-purchase", "google-play", "apple", "receipt-verification"],
    "authors": [
        {
            "name": "fukazawa"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^7.0",
        "google/apiclient": "^2.18"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fukazawa\\Iap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fukazawa\\Iap\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
