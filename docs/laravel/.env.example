# Google Play
IAP_GOOGLE_APP_NAME="My App"
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
IAP_GOOGLE_PACKAGE_NAME=com.example.myapp

# Apple App Store
IAP_APPLE_BUNDLE_ID=com.example.myapp
IAP_APPLE_ISSUER_ID=your-issuer-id
IAP_APPLE_KEY_ID=your-key-id
IAP_APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8
IAP_APPLE_ENVIRONMENT=sandbox
